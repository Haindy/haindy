# Normalize line endings across platforms.
* text=auto eol=lf

# Shell scripts and text files on all platforms use LF.
*.sh text eol=lf
*.py text eol=lf
*.toml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.jsonl text eol=lf
*.md text eol=lf
*.j2 text eol=lf
*.txt text eol=lf
*.cfg text eol=lf
*.ini text eol=lf

# Windows-native scripts must ship with CRLF so cmd.exe / PowerShell run them.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary assets: never touch.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webm binary
*.mp4 binary
*.webp binary
*.pdf binary
