# Core OpenAI settings
OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=gpt-5.2
OPENAI_MAX_RETRIES=3
OPENAI_REQUEST_TIMEOUT_SECONDS=900

# Per-agent model overrides
# (If unset, model falls back to OPENAI_MODEL / OPENAI_REQUEST_TIMEOUT_SECONDS)
HAINDY_SCOPE_TRIAGE_MODEL=gpt-5.2
HAINDY_SCOPE_TRIAGE_REASONING_LEVEL=high
HAINDY_SCOPE_TRIAGE_MODALITIES=text

HAINDY_TEST_PLANNER_MODEL=gpt-5.2
HAINDY_TEST_PLANNER_REASONING_LEVEL=high
HAINDY_TEST_PLANNER_MODALITIES=text

HAINDY_TEST_RUNNER_MODEL=gpt-5.2
HAINDY_TEST_RUNNER_REASONING_LEVEL=medium
HAINDY_TEST_RUNNER_MODALITIES=text,vision

HAINDY_ACTION_AGENT_MODEL=gpt-5.2
HAINDY_ACTION_AGENT_REASONING_LEVEL=low
HAINDY_ACTION_AGENT_MODALITIES=text,vision

HAINDY_SITUATIONAL_AGENT_MODEL=gpt-5.2
HAINDY_SITUATIONAL_AGENT_REASONING_LEVEL=high
HAINDY_SITUATIONAL_AGENT_MODALITIES=text

# Execution behavior
MAX_TEST_STEPS=100
STEP_TIMEOUT=30000
MAX_RETRIES_PER_STEP=3
SCREENSHOT_QUALITY=80

# File and cache paths
DATA_DIR=data
REPORTS_DIR=reports
SCREENSHOTS_DIR=data/screenshots
CACHE_DIR=.cache
HAINDY_TASK_PLAN_CACHE_PATH=data/task_plan_cache.json
HAINDY_EXECUTION_REPLAY_CACHE_PATH=data/execution_replay_cache.json
HAINDY_DESKTOP_COORDINATE_CACHE_PATH=data/desktop_cache/coordinates.json
HAINDY_DESKTOP_SCREENSHOT_DIR=data/screenshots/desktop
HAINDY_MAX_SCREENSHOTS=12

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=
MODEL_LOG_PATH=data/model_logs/model_calls.jsonl

# Desktop automation
HAINDY_DESKTOP_RESOLUTION=1920,1080
HAINDY_DESKTOP_KEYBOARD_LAYOUT=us
HAINDY_DESKTOP_KEYBOARD_SCANCODES=true
HAINDY_DESKTOP_KEY_DELAY_MS=12
HAINDY_DESKTOP_ENABLE_RESOLUTION_SWITCH=true
HAINDY_DESKTOP_DISPLAY=
DISPLAY=
HAINDY_DESKTOP_CLIPBOARD_TIMEOUT_SECONDS=3.0
HAINDY_DESKTOP_CLIPBOARD_HOLD_SECONDS=15.0

# Desktop screen recording
HAINDY_ENABLE_SCREEN_RECORDING=false
HAINDY_SCREEN_RECORDING_OUTPUT_DIR=reports/recordings
HAINDY_SCREEN_RECORDING_FRAMERATE=30
HAINDY_SCREEN_RECORDING_DRAW_CURSOR=true
HAINDY_SCREEN_RECORDING_PREFIX=haindy-agent

# Computer Use (OpenAI, Google, or Anthropic)
HAINDY_ACTIONS_USE_COMPUTER_TOOL=false
HAINDY_COMPUTER_USE_MODEL=computer-use-preview
ACTIONS_USE_COMPUTER_TOOL=
COMPUTER_USE_MODEL=
CU_PROVIDER=google
GOOGLE_CU_MODEL=gemini-2.5-computer-use-preview-10-2025
ANTHROPIC_API_KEY=
ANTHROPIC_CU_MODEL=claude-sonnet-4-6
ANTHROPIC_CU_BETA=computer-use-2025-11-24
ANTHROPIC_CU_MAX_TOKENS=16384
VERTEX_API_KEY=
VERTEX_PROJECT=
VERTEX_LOCATION=us-central1
CU_SAFETY_POLICY=auto_approve
HAINDY_ACTIONS_COMPUTER_TOOL_MAX_TURNS=12
HAINDY_ACTIONS_COMPUTER_TOOL_LOOP_WINDOW=3
HAINDY_ACTIONS_COMPUTER_TOOL_ACTION_TIMEOUT_MS=600000
HAINDY_ACTIONS_COMPUTER_TOOL_STABILIZATION_WAIT_MS=1000
HAINDY_ACTIONS_COMPUTER_TOOL_FAIL_FAST=true
HAINDY_ACTIONS_COMPUTER_TOOL_ALLOWED_DOMAINS=
HAINDY_ACTIONS_COMPUTER_TOOL_BLOCKED_DOMAINS=
HAINDY_SCROLL_TURN_MULTIPLIER=3.0
HAINDY_SCROLL_DEFAULT_MAGNITUDE=450
HAINDY_SCROLL_MAX_MAGNITUDE=600

# Security and runtime behavior
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
SANITIZE_SCREENSHOTS=true
DEBUG_MODE=false
SAVE_AGENT_CONVERSATIONS=true

# Execution cache controls
HAINDY_ENABLE_EXECUTION_REPLAY_CACHE=true
