# NOTE: This file is the legacy configuration method. For new setups, prefer:
#
#   haindy --auth-set openai      (store API key in system keychain)
#   haindy --auth-set google      (store Vertex credentials interactively)
#   haindy --auth-set anthropic   (store API key in system keychain)
#
# Non-secret settings can be configured in ~/.haindy/settings.json.
# Run `haindy --config-migrate` to import this file into the new system.
#
# Environment variables here still work and take priority over all other sources,
# so they remain useful for CI/CD and containerized environments.

# Core OpenAI settings
HAINDY_OPENAI_API_KEY=your_api_key_here
HAINDY_OPENAI_MODEL=gpt-5.4
HAINDY_OPENAI_CODEX_MODEL=gpt-5.4
HAINDY_OPENAI_MAX_RETRIES=3
HAINDY_OPENAI_REQUEST_TIMEOUT_SECONDS=900

# Per-agent model overrides
# If unset, each agent uses its default configuration from src/config/settings.py.
HAINDY_SCOPE_TRIAGE_MODEL=gpt-5.4
HAINDY_SCOPE_TRIAGE_REASONING_LEVEL=high
HAINDY_SCOPE_TRIAGE_MODALITIES=text

HAINDY_TEST_PLANNER_MODEL=gpt-5.4
HAINDY_TEST_PLANNER_REASONING_LEVEL=high
HAINDY_TEST_PLANNER_MODALITIES=text

HAINDY_TEST_RUNNER_MODEL=gpt-5.4
HAINDY_TEST_RUNNER_REASONING_LEVEL=medium
HAINDY_TEST_RUNNER_MODALITIES=text,vision

HAINDY_SITUATIONAL_AGENT_MODEL=gpt-5.4
HAINDY_SITUATIONAL_AGENT_REASONING_LEVEL=high
HAINDY_SITUATIONAL_AGENT_MODALITIES=text

# Execution behavior
HAINDY_MAX_TEST_STEPS=100
HAINDY_STEP_TIMEOUT=30000
HAINDY_MAX_RETRIES_PER_STEP=3
HAINDY_SCREENSHOT_QUALITY=80

# File and cache paths
HAINDY_HOME=~/.haindy
# By default, data artifacts are written under:
#   HAINDY_HOME/data/projects/<project-id>/
# where <project-id> is based on the resolved current working directory.
# Uncomment HAINDY_DATA_DIR to use an exact custom data root. Legacy copied
# values like `data` continue to write to ./data until the override is removed.
# HAINDY_DATA_DIR=/absolute/path/to/haindy-data
HAINDY_REPORTS_DIR=reports
# Specific data-family path overrides below are intentionally commented out.
# If set, they win over HAINDY_DATA_DIR and the project-scoped defaults.
# HAINDY_SCREENSHOTS_DIR=/absolute/path/to/haindy-data/screenshots
HAINDY_CACHE_DIR=.cache
# HAINDY_TASK_PLAN_CACHE_PATH=/absolute/path/to/haindy-data/task_plan_cache.json
# HAINDY_PLANNING_CACHE_PATH=/absolute/path/to/haindy-data/planning_cache.json
# HAINDY_SITUATIONAL_CACHE_PATH=/absolute/path/to/haindy-data/situational_cache.json
# HAINDY_EXECUTION_REPLAY_CACHE_PATH=/absolute/path/to/haindy-data/execution_replay_cache.json
# HAINDY_LINUX_COORDINATE_CACHE_PATH=/absolute/path/to/haindy-data/linux_cache/coordinates.json
# HAINDY_WINDOWS_COORDINATE_CACHE_PATH=/absolute/path/to/haindy-data/windows_cache/coordinates.json
# HAINDY_WINDOWS_SCREENSHOT_DIR=/absolute/path/to/haindy-data/screenshots/windows
HAINDY_WINDOWS_KEYBOARD_LAYOUT=us
HAINDY_WINDOWS_KEY_DELAY_MS=12
HAINDY_WINDOWS_CLIPBOARD_TIMEOUT_SECONDS=3.0
HAINDY_WINDOWS_CLIPBOARD_HOLD_SECONDS=15.0
# HAINDY_DESKTOP_SCREENSHOT_DIR=/absolute/path/to/haindy-data/screenshots/desktop
HAINDY_MAX_SCREENSHOTS=12

# Logging
HAINDY_LOG_LEVEL=INFO
HAINDY_LOG_FORMAT=text
HAINDY_LOG_FILE=
# HAINDY_MODEL_LOG_PATH=/absolute/path/to/haindy-data/model_logs/model_calls.jsonl

# Desktop automation
HAINDY_AUTOMATION_BACKEND=desktop
HAINDY_DESKTOP_RESOLUTION=1920,1080
# auto detects the active XKB layout; use us or es to force a layout.
HAINDY_DESKTOP_KEYBOARD_LAYOUT=auto
HAINDY_DESKTOP_KEYBOARD_SCANCODES=true
HAINDY_DESKTOP_KEY_DELAY_MS=12
HAINDY_DESKTOP_ENABLE_RESOLUTION_SWITCH=true
# Optional X11 display override used by HAINDY's desktop capture flow.
# Leave unset to use the process DISPLAY environment variable, or ":0" if that
# is also unset.
HAINDY_DESKTOP_DISPLAY=
# Standard X11 display environment variable. HAINDY only reads this when
# HAINDY_DESKTOP_DISPLAY is unset, and only if DISPLAY is exported in the shell
# environment. Setting DISPLAY in .env does not populate os.environ.
DISPLAY=
HAINDY_DESKTOP_CLIPBOARD_TIMEOUT_SECONDS=3.0
HAINDY_DESKTOP_CLIPBOARD_HOLD_SECONDS=15.0

# Mobile automation (ADB / Android)
# HAINDY_MOBILE_SCREENSHOT_DIR=/absolute/path/to/haindy-data/screenshots/mobile
# HAINDY_MOBILE_COORDINATE_CACHE_PATH=/absolute/path/to/haindy-data/mobile_cache/coordinates.json
HAINDY_MOBILE_DEFAULT_ADB_SERIAL=
HAINDY_MOBILE_ADB_TIMEOUT_SECONDS=15.0

# iOS automation (idb)
# HAINDY_IOS_SCREENSHOT_DIR=/absolute/path/to/haindy-data/screenshots/ios
# HAINDY_IOS_COORDINATE_CACHE_PATH=/absolute/path/to/haindy-data/ios_cache/coordinates.json
HAINDY_IOS_DEFAULT_DEVICE_UDID=
HAINDY_IOS_IDB_TIMEOUT_SECONDS=15.0

# macOS desktop automation (pynput + mss)
# Requires Accessibility permission for keyboard injection and
# Screen Recording permission for screenshot capture.
# Grant both in System Settings -> Privacy & Security.
# HAINDY_MACOS_SCREENSHOT_DIR=/absolute/path/to/haindy-data/screenshots/macos
# HAINDY_MACOS_COORDINATE_CACHE_PATH=/absolute/path/to/haindy-data/macos_cache/coordinates.json
HAINDY_MACOS_KEYBOARD_LAYOUT=us
HAINDY_MACOS_KEY_DELAY_MS=12
HAINDY_MACOS_CLIPBOARD_TIMEOUT_SECONDS=3.0
HAINDY_MACOS_CLIPBOARD_HOLD_SECONDS=15.0

# Desktop screen recording
HAINDY_ENABLE_SCREEN_RECORDING=false
HAINDY_SCREEN_RECORDING_OUTPUT_DIR=reports/recordings
HAINDY_SCREEN_RECORDING_FRAMERATE=30
HAINDY_SCREEN_RECORDING_DRAW_CURSOR=true
HAINDY_SCREEN_RECORDING_PREFIX=haindy-agent

# Non-CU (planning/analysis) provider -- openai, openai-codex, anthropic, or google
# openai-codex is non-CU only; there is no HAINDY_OPENAI_CODEX_CU_MODEL.
HAINDY_AGENT_PROVIDER=openai

# Provider-specific non-CU models
HAINDY_ANTHROPIC_MODEL=claude-sonnet-4-6
HAINDY_GOOGLE_MODEL=gemini-3-flash-preview

# Computer Use provider and provider-specific CU models
HAINDY_COMPUTER_USE_MODEL=gpt-5.4
HAINDY_CU_PROVIDER=google
HAINDY_GOOGLE_CU_MODEL=gemini-3-flash-preview
HAINDY_ANTHROPIC_API_KEY=
HAINDY_ANTHROPIC_CU_MODEL=claude-sonnet-4-6
HAINDY_ANTHROPIC_CU_BETA=computer-use-2025-11-24
HAINDY_ANTHROPIC_CU_MAX_TOKENS=16384
HAINDY_VERTEX_API_KEY=
HAINDY_VERTEX_PROJECT=
HAINDY_VERTEX_LOCATION=us-central1
HAINDY_CU_SAFETY_POLICY=auto_approve
HAINDY_OPENAI_CU_TRANSPORT=responses_websocket
HAINDY_CU_VISUAL_MODE=keyframe_patch
HAINDY_CU_CARTOGRAPHY_MODEL=
HAINDY_CU_KEYFRAME_MAX_TURNS=3
HAINDY_CU_PATCH_MAX_AREA_RATIO=0.35
HAINDY_CU_PATCH_MARGIN_RATIO=0.12
HAINDY_ACTIONS_COMPUTER_TOOL_MAX_TURNS=12
HAINDY_ACTIONS_COMPUTER_TOOL_LOOP_WINDOW=3
HAINDY_ACTIONS_COMPUTER_TOOL_ACTION_TIMEOUT_SECONDS=600
HAINDY_ACTIONS_COMPUTER_TOOL_STABILIZATION_WAIT_MS=1000
HAINDY_ACTIONS_COMPUTER_TOOL_FAIL_FAST=true
HAINDY_ACTIONS_COMPUTER_TOOL_ALLOWED_DOMAINS=
HAINDY_ACTIONS_COMPUTER_TOOL_BLOCKED_DOMAINS=
HAINDY_SCROLL_TURN_MULTIPLIER=3.0
HAINDY_SCROLL_DEFAULT_MAGNITUDE=450
HAINDY_SCROLL_MAX_MAGNITUDE=600

# Security and runtime behavior
HAINDY_RATE_LIMIT_ENABLED=true
HAINDY_RATE_LIMIT_REQUESTS_PER_MINUTE=60
HAINDY_SANITIZE_SCREENSHOTS=true
HAINDY_DEBUG_MODE=false
HAINDY_SAVE_AGENT_CONVERSATIONS=true

# Execution cache controls
HAINDY_ENABLE_PLANNING_CACHE=true
HAINDY_ENABLE_SITUATIONAL_CACHE=true
HAINDY_ENABLE_EXECUTION_REPLAY_CACHE=true
